# ============================================================
# SDU Archive 环境变量配置模板
# 使用方法：复制本文件为 .env，然后修改下面的值
#   cp .env.example .env
#   nano .env
# ============================================================

# -------------------- AI 配置（可选） --------------------
# 填了才有 AI 问答功能；全部留空网站也能正常运行，但 AI 相关功能不可用。
#
# 本项目兼容所有提供 OpenAI 格式 API 的服务，包括：
#   - OpenAI 官方  → OPENAI_API_BASE=https://api.openai.com/v1  OPENAI_MODEL=gpt-4o-mini
#   - DeepSeek     → OPENAI_API_BASE=https://api.deepseek.com    OPENAI_MODEL=deepseek-chat
#   - 通义千问     → OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1  OPENAI_MODEL=qwen-plus
#   - 本地 Ollama  → OPENAI_API_BASE=http://localhost:11434/v1   OPENAI_MODEL=qwen2.5

# 你的 API 密钥（从对应服务商的控制台获取）
OPENAI_API_KEY=sk-

# API 地址
OPENAI_API_BASE=https://api.deepseek.com

# 模型名称（要与上面的 API 地址匹配）
OPENAI_MODEL=deepseek-chat

# -------------------- Embedding 配置（推荐与 LLM 分离） --------------------
# RAG 检索向量化使用单独配置；若留空则自动回退到 OPENAI_* 配置。
# 注意：DeepSeek 不提供 /embeddings，请务必填写支持 embeddings 的服务。
EMBEDDING_API_KEY=sk
EMBEDDING_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024

# -------------------- 安全配置（必须修改！） --------------------

# JWT 加密密钥，保护用户登录安全。
# 生成方法：在终端运行  openssl rand -hex 32  复制输出的那串字符粘贴到这里
SECRET_KEY=change-me-to-a-secure-random-string

# 管理员账号（首次启动时自动创建）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin12345678

# -------------------- 数据库（一般不需要改） --------------------
DATABASE_URL=postgresql+psycopg2://sdu:sdu@db:5432/sdu_archive

# -------------------- MinIO 对象存储（一般不需要改） --------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# 如需修改 MinIO root 凭据（推荐生产环境修改）：
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=documents

# -------------------- 其他可选配置 --------------------

# 后端 API 限流：每个 IP 每分钟最多请求次数（默认 60）
RATE_LIMIT_PER_MINUTE=60

# 允许的跨域来源（逗号分隔）。
# ⚠️ 绑定域名后，务必改成你的实际域名，例如：https://yourdomain.com
CORS_ORIGINS=http://localhost:18080,http://localhost:3000

# -------------------- 端口映射（可选，一般不需要改） --------------------
# 如果服务器上这些端口被占用了，可以改成其他数字
# FRONTEND_HOST_PORT=18080
# API_HOST_PORT=18000
# POSTGRES_HOST_PORT=15433
# MINIO_API_PORT=19002
# MINIO_CONSOLE_PORT=19003
