# SDU Archive Environment Variables Template
# Copy this file to .env and fill in your values

# OpenAI API Key (optional, for semantic embeddings and LLM answers)
OPENAI_API_KEY=

# OpenAI Model Selection (default: gpt-4o-mini, alternatives: gpt-4o, gpt-3.5-turbo)
OPENAI_MODEL=gpt-4o-mini

# Database Configuration
DATABASE_URL=postgresql+psycopg2://sdu:sdu@db:5432/sdu_archive

# MinIO Object Storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=documents

# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
SECRET_KEY=change-me-to-a-secure-random-string

# Admin Account (CHANGE PASSWORD IN PRODUCTION!)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# CORS Origins (comma-separated list)
CORS_ORIGINS=http://localhost:18080,http://localhost:3000
